# Ollama model name
# Default: qwen2.5-coder:7b-instruct (hackathon target, 8GB VRAM)
# For 4GB VRAM use: qwen2.5-coder:3b-instruct
# If you created a custom Modelfile: truehack
OLLAMA_MODEL=qwen2.5-coder:7b-instruct

# Ollama API base URL (OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
