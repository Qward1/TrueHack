# Shared/base Ollama model. TaskPlanner will use this unless overridden below.
OLLAMA_MODEL=qwen3.5:9b

# Per-agent Ollama model overrides.
OLLAMA_MODEL_CODE_GENERATOR=qwen2.5-coder:7b-instruct
OLLAMA_MODEL_VERIFICATION_FIXER=qwen2.5-coder:7b-instruct
OLLAMA_MODEL_VALIDATION_FIXER=qwen2.5-coder:7b-instruct
OLLAMA_MODEL_REQUIREMENTS_VERIFIER=qwen2.5-coder:7b-instruct

# Ollama API base URL (OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Maximum number of simultaneous chat/completions requests sent to Ollama
# from this app process. Use 1 to avoid parallel model execution.
OLLAMA_MAX_CONCURRENT_REQUESTS=1

# Lua interpreter binary (default: lua55)
# If lua55 is not in PATH, use full path: C:\lua55\lua55.exe
LUA_BIN=C:/Users/Admin/Desktop/lua55/lua55.exe

# TaskPlanner LLM agent (analyzes user request before code generation)
PLANNER_ENABLED=true
OLLAMA_REASONING_EFFORT_TASK_PLANNER=none

# Optional shared / per-agent thinking control.
# Allowed values: none, low, medium, high.
# Aliases: true/on/1 -> medium, false/off/0 -> none
# If not set, qwen3.5:9b is still called with thinking disabled automatically.
#
# OLLAMA_REASONING_EFFORT=medium
# OLLAMA_REASONING_EFFORT_TASK_PLANNER=none
# OLLAMA_REASONING_EFFORT_CODE_GENERATOR=medium
# OLLAMA_REASONING_EFFORT_REQUIREMENTS_VERIFIER=none

# Optional template RAG for CodeGenerator.
# The retriever searches template descriptions from the JSONL knowledge base
# and injects only the matched Lua templates into the generation prompt.
# Uses Ollama embeddings when available and falls back to lexical ranking.
RAG_TEMPLATES_ENABLED=true
RAG_TEMPLATES_KB_PATH=lua_rag_templates_kb.jsonl
RAG_TEMPLATES_TOP_K=2
RAG_TEMPLATES_REQUIRE_PLANNER=true
# Recommended Ollama embedding model, for example: nomic-embed-text
RAG_TEMPLATES_EMBED_MODEL=nomic-embed-text
